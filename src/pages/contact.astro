---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="Contact | Creative Portfolio">
  <section class="page-hero">
    <p class="eyebrow">Contact</p>
    <h1>Let’s create something visual.</h1>
    <p>
      如果你想联系我，可以先把这里改成你的邮箱、Instagram、X、Behance 或其他平台链接。
    </p>
  </section>

  <section class="contact-box">
    <a href="mailto:yourmail@example.com" class="contact-link">
      yourmail@example.com
    </a>

    <div class="social-links">
      <a href="#">Instagram</a>
      <a href="#">Behance</a>
      <a href="#">GitHub</a>
    </div>
  </section>
</BaseLayout>